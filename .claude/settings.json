{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash(gh pr create*)",
        "hooks": [
          {
            "type": "command",
            "command": "echo '⚠️ PR作成前にレビューAgentを起動してください。\\n手順: 1) make build && make test 2) レビューAgentでdiff確認 3) 指摘事項修正後にPR作成'"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(make *)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git checkout*)",
      "Bash(git switch*)",
      "Bash(git branch*)",
      "Bash(git add*)",
      "Bash(git commit*)",
      "Bash(git push*)",
      "Bash(gh pr *)",
      "Bash(gh issue *)",
      "Bash(gh label *)",
      "Bash(xcodebuild *)",
      "Bash(cd supabase*)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(which *)",
      "Bash(mkdir *)"
    ]
  }
}
